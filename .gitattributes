# Normalize line endings for the whole repo so Windows and Linux mounts
# stop producing CRLF/LF churn in diffs. Text is stored LF in the repo;
# Git converts on checkout per each platform's core.autocrlf setting.
* text=auto eol=lf

# Explicit binaries so Git never tries to normalize them.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.mp4   binary
*.mov   binary
*.webm  binary
*.zip   binary
